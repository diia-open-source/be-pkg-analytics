{
    "extends": "../tsconfig",
    "compilerOptions": {
        "types": ["vite/client", "vitest/globals"],
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "isolatedModules": true,
        "baseUrl": "../",
        "paths": {
            "@services/*": ["src/services/*"],
            "@interfaces/*": ["src/interfaces/*"],
            "@src/*": ["src/*"],
            "@tests/*": ["tests/*"]
        },
        "noEmit": true
    },
    "include": ["./**/*", "../vitest.config.mts"]
}
