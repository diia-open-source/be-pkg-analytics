{
    "name": "@diia-inhouse/analytics",
    "version": "1.72.0",
    "description": "Analytics utils",
    "main": "dist/index.js",
    "types": "dist/types/index.d.ts",
    "repository": "https://github.com/diia-open-source/be-pkg-analytics.git",
    "author": "Diia",
    "license": null,
    "files": [
        "dist"
    ],
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "tsc",
        "semantic-release": "semantic-release",
        "lint": "eslint . && prettier --check .",
        "lint-fix": "eslint --fix . && prettier --write .",
        "lint:lockfile": "lockfile-lint --path package-lock.json --allowed-hosts registry.npmjs.org --validate-https",
        "prepare": "npm run build",
        "test": "vitest run",
        "test:watch": "vitest watch",
        "find-circulars": "madge --circular --extensions ts ./"
    },
    "dependencies": {
        "bson": "6.10.4"
    },
    "peerDependencies": {
        "@diia-inhouse/types": ">=2.16.0",
        "@diia-inhouse/utils": ">=2.2.0"
    },
    "devDependencies": {
        "@diia-inhouse/configs": "6.1.1",
        "@diia-inhouse/diia-logger": "3.16.0",
        "@diia-inhouse/eslint-config": "8.2.4",
        "@diia-inhouse/test": "7.2.0",
        "@diia-inhouse/types": "11.3.0",
        "@diia-inhouse/utils": "5.3.0",
        "@types/bson": "4.2.4",
        "@types/node": "25.3.3",
        "@vitest/coverage-v8": "4.0.18",
        "@vitest/ui": "4.0.18",
        "eslint": "9.30.1",
        "glob": "13.0.6",
        "lockfile-lint": "4.14.1",
        "madge": "8.0.0",
        "prettier": "3.8.1",
        "rimraf": "6.1.3",
        "semantic-release": "24.2.6",
        "ts-node": "10.9.2",
        "ts-patch": "3.3.0",
        "type-fest": "4.41.0",
        "typescript": "5.9.3",
        "vite-tsconfig-paths": "6.1.1",
        "vitest": "4.0.18",
        "vitest-mock-extended": "3.1.0"
    },
    "release": {
        "extends": "@diia-inhouse/configs/dist/semantic-release/package",
        "branches": [
            "main"
        ]
    },
    "commitlint": {
        "extends": "@diia-inhouse/configs/dist/commitlint"
    },
    "eslintConfig": {
        "extends": "@diia-inhouse/eslint-config",
        "overrides": [
            {
                "files": [
                    "*.ts"
                ],
                "parserOptions": {
                    "project": [
                        "./tsconfig.json",
                        "./tests/tsconfig.json"
                    ]
                }
            }
        ]
    },
    "prettier": "@diia-inhouse/eslint-config/prettier",
    "madge": {
        "tsConfig": "./tsconfig.json"
    }
}
